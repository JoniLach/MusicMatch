<Page x:Class="MusicMatch.ManageSchedulePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:MusicMatch"
      mc:Ignorable="d"
      d:DesignHeight="700" d:DesignWidth="900"
      Title="Manage Schedule" Background="#121212">

    <Page.Resources>
        <local:StatusColorConverter x:Key="StatusColorConverter"/>
        <local:StatusTextConverter x:Key="StatusTextConverter"/>
        <local:InverseBoolConverter x:Key="InverseBoolConverter"/>
        <local:RateButtonVisibilityConverter x:Key="RateButtonVisConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="TabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="bd" Background="Transparent"
                                BorderThickness="0,0,0,2" BorderBrush="Transparent"
                                Padding="20,10">
                            <TextBlock Text="{TemplateBinding Header}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       FontSize="{TemplateBinding FontSize}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#1DB954"/>
                                <Setter Property="Foreground" Value="#1DB954"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}" Opacity="{TemplateBinding Opacity}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Text="Manage Schedule" FontSize="28" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,16"/>

        <!-- Tabs -->
        <TabControl Grid.Row="1" x:Name="tabMain" Background="Transparent" BorderThickness="0">
            <TabControl.Resources>
                <Style TargetType="TabPanel">
                    <Setter Property="Background" Value="Transparent"/>
                </Style>
            </TabControl.Resources>

            <!-- ===== TAB 1: My Slots ===== -->
            <TabItem Header="My Slots" Style="{StaticResource TabItemStyle}">
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Add / Edit Slot Form -->
                    <Border Background="#1E1E1E" CornerRadius="10" Padding="20" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock x:Name="txtFormTitle" Text="Add a New Slot"
                                       Foreground="#1DB954" FontSize="14" FontWeight="Bold" Margin="0,0,0,12"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <StackPanel Margin="0,0,20,0">
                                    <TextBlock Text="Date" Foreground="White" Margin="0,0,0,5"/>
                                    <DatePicker x:Name="dpDate" Foreground="White" Width="150" Height="30" VerticalContentAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,20,0">
                                    <TextBlock Text="Start Time" Foreground="White" Margin="0,0,0,5"/>
                                    <ComboBox x:Name="cmbTime" Foreground="White" Width="100" Height="30" VerticalContentAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,20,0">
                                    <TextBlock Text="Duration (min)" Foreground="#AAAAAA" Margin="0,0,0,5"/>
                                    <TextBox x:Name="txtDuration" Text="60" Width="80" Height="30"
                                             VerticalContentAlignment="Center" Background="#333333"
                                             Foreground="White" BorderThickness="0"/>
                                </StackPanel>
                                <Button x:Name="btnAddSlot" Content="Add Slot" Click="btnAddSlot_Click"
                                        Width="110" Height="30" VerticalAlignment="Bottom"
                                        Background="#1DB954" Foreground="White" Style="{StaticResource ActionBtn}"/>
                                <Button x:Name="btnCancelEdit" Content="Cancel" Click="btnCancelEdit_Click"
                                        Width="80" Height="30" VerticalAlignment="Bottom" Margin="8,0,0,0"
                                        Background="#555555" Foreground="White" Style="{StaticResource ActionBtn}"
                                        Visibility="Collapsed"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Slots List -->
                    <ListView x:Name="lstSchedule" Grid.Row="1" Background="Transparent" BorderThickness="0">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Margin" Value="0,0,0,8"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border Background="#1E1E1E" CornerRadius="8" Padding="15,12">
                                                <ContentPresenter/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Lesson info -->
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding LessonDate, StringFormat=D}"
                                                   Foreground="White" FontWeight="SemiBold" FontSize="15"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Text="{Binding StartTime}" Foreground="#BBBBBB" FontSize="13"/>
                                            <TextBlock Text=" • " Foreground="#555555"/>
                                            <TextBlock Text="{Binding Duration}" Foreground="#BBBBBB" FontSize="13"/>
                                            <TextBlock Text=" mins" Foreground="#BBBBBB" FontSize="13"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding StudentName, StringFormat='Student: {0}'}"
                                                   Foreground="#1DB954" FontSize="12" Margin="0,4,0,0"
                                                   Visibility="{Binding IsBooked, Converter={StaticResource BoolToVis}}"/>
                                    </StackPanel>

                                    <!-- Action buttons -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                                        <!-- Rate: only for past booked lessons not yet rated by teacher -->
                                        <Button Content="Rate Student" Tag="{Binding}" Click="btnRate_Click"
                                                Background="#F59E0B" Foreground="White"
                                                Style="{StaticResource ActionBtn}" Margin="0,0,6,0">
                                            <Button.Visibility>
                                                <MultiBinding Converter="{StaticResource RateButtonVisConverter}">
                                                    <Binding Path="IsBooked"/>
                                                    <Binding Path="LessonDate"/>
                                                    <Binding Path="TeacherRating"/>
                                                </MultiBinding>
                                            </Button.Visibility>
                                        </Button>

                                        <!-- Edit: disabled for booked slots -->
                                        <Button Content="Edit" Tag="{Binding}" Click="btnEditSlot_Click"
                                                Background="#3B82F6" Foreground="White"
                                                Style="{StaticResource ActionBtn}" Margin="0,0,6,0"
                                                IsEnabled="{Binding IsBooked, Converter={StaticResource InverseBoolConverter}}"
                                                ToolTip="Cannot edit a booked slot"/>

                                        <!-- Delete: always shown -->
                                        <Button Content="Delete" Tag="{Binding}" Click="btnDeleteSlot_Click"
                                                Background="#EF4444" Foreground="White"
                                                Style="{StaticResource ActionBtn}" Margin="0,0,10,0"/>
                                    </StackPanel>

                                    <!-- Status badge -->
                                    <Border Grid.Column="2" CornerRadius="4" Padding="12,4" MinWidth="90"
                                            VerticalAlignment="Center"
                                            Background="{Binding IsBooked, Converter={StaticResource StatusColorConverter}}">
                                        <TextBlock Text="{Binding IsBooked, Converter={StaticResource StatusTextConverter}}"
                                                   Foreground="White" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </TabItem>

            <!-- ===== TAB 2: Schedule Directly ===== -->
            <TabItem Header="Schedule Directly" Style="{StaticResource TabItemStyle}">
                <Grid Margin="0,16,0,0">
                    <Border Background="#1E1E1E" CornerRadius="10" Padding="24"
                            MaxWidth="480" HorizontalAlignment="Left" VerticalAlignment="Top">
                        <StackPanel>
                            <TextBlock Text="Create a confirmed lesson with a specific student"
                                       Foreground="#AAAAAA" FontSize="13" Margin="0,0,0,20"/>

                            <TextBlock Text="Student" Foreground="White" Margin="0,0,0,6"/>
                            <ComboBox x:Name="cmbStudent" Width="340" Height="32"
                                      HorizontalAlignment="Left" Margin="0,0,0,16"
                                      Background="#333333" Foreground="White">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding FirstName}"/>
                                            <TextBlock Text=" "/>
                                            <TextBlock Text="{Binding LastName}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <TextBlock Text="Date" Foreground="White" Margin="0,0,0,6"/>
                            <DatePicker x:Name="dpDirectDate" Width="200" Height="30"
                                        HorizontalAlignment="Left" Margin="0,0,0,16"/>

                            <TextBlock Text="Start Time" Foreground="White" Margin="0,0,0,6"/>
                            <ComboBox x:Name="cmbDirectTime" Width="120" Height="30"
                                      HorizontalAlignment="Left" Margin="0,0,0,16"/>

                            <TextBlock Text="Duration (minutes)" Foreground="#AAAAAA" Margin="0,0,0,6"/>
                            <TextBox x:Name="txtDirectDuration" Text="60" Width="100" Height="30"
                                     HorizontalAlignment="Left" Background="#333333" Foreground="White"
                                     BorderThickness="0" VerticalContentAlignment="Center" Margin="0,0,0,24"/>

                            <Button x:Name="btnScheduleDirect" Content="Schedule Lesson"
                                    Click="btnScheduleDirect_Click"
                                    Height="36" Width="200" HorizontalAlignment="Left"
                                    Background="#1DB954" Foreground="White"
                                    Style="{StaticResource ActionBtn}" FontSize="13"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Footer -->
        <Button Grid.Row="2" Content="Back" Click="btnBack_Click"
                Width="100" Height="35" HorizontalAlignment="Left" Margin="0,16,0,0"
                Background="#333333" Foreground="White" BorderThickness="0"
                Style="{StaticResource ActionBtn}" FontSize="13"/>
    </Grid>
</Page>
